digraph SoftwareDevelopmentAgreement {
    rankdir=TB;
    splines=curved;
    concentrate=true;
    nodesep=0.9;
    ranksep=1.2;
    graph [fontname="Helvetica" fontsize=13 label="SoftwareDevelopmentAgreement — State Machine" labelloc=t labeljust=c pad=0.5];
    node  [fontname="Helvetica" fontsize=11 margin="0.25,0.15"];
    edge  [fontname="Helvetica" fontsize=10];

    // Entry point
    __start [label="" shape=point width=0.2];
    __start -> AwaitingKickoff;

    // States
    AwaitingKickoff [label="Awaiting Kickoff" shape=box style="rounded,filled" fillcolor="#f5f5f5" color="#555555"];
    Development [label="Development" shape=box style="rounded,filled" fillcolor="#f5f5f5" color="#555555"];
    Review [label="Review" shape=box style="rounded,filled" fillcolor="#f5f5f5" color="#555555"];
    AwaitingFinalPayment [label="Awaiting Final Payment" shape=box style="rounded,filled" fillcolor="#f5f5f5" color="#555555"];
    Fulfilled [label="Fulfilled" shape=doublecircle style=filled fillcolor="#b7f5b7" color="#2e7d32" penwidth=2 width=1.1 height=1.1 fixedsize=true];
    DeveloperBreached [label="Developer Breached" shape=doublecircle style=filled fillcolor="#ffcdd2" color="#c62828" penwidth=2 width=1.1 height=1.1 fixedsize=true];
    ClientBreached [label="Client Breached" shape=doublecircle style=filled fillcolor="#ffcdd2" color="#c62828" penwidth=2 width=1.1 height=1.1 fixedsize=true];
    Expired [label="Expired" shape=doublecircle style=filled fillcolor="#fff9c4" color="#f57f17" penwidth=2 width=1.1 height=1.1 fixedsize=true];

    // Transitions
    AwaitingKickoff -> Development [label="Kickoff Complete"]
    AwaitingKickoff -> Expired [label="after 90 days"]
    Development -> Review [label="Prototype Approved"]
    Development -> DeveloperBreached [label="breach: Developer"]
    Development -> Expired [label="after 90 days"]
    Review -> AwaitingFinalPayment [label="Review Complete"]
    Review -> ClientBreached [label="breach: Client"]
    Review -> Expired [label="after 14 days"]
    AwaitingFinalPayment -> Fulfilled [label="Payment Received"]
    AwaitingFinalPayment -> Expired [label="after 30 days"]
    AwaitingFinalPayment -> ClientBreached [label="breach: Client"]
}
