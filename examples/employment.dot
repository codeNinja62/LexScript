digraph EmploymentAgreement {
    rankdir=TB;
    splines=curved;
    concentrate=true;
    nodesep=0.9;
    ranksep=1.2;
    graph [fontname="Helvetica" fontsize=13 label="EmploymentAgreement — State Machine" labelloc=t labeljust=c pad=0.5];
    node  [fontname="Helvetica" fontsize=11 margin="0.25,0.15"];
    edge  [fontname="Helvetica" fontsize=10];

    // Entry point
    __start [label="" shape=point width=0.2];
    __start -> Probation;

    // States
    Probation [label="Probation" shape=box style="rounded,filled" fillcolor="#f5f5f5" color="#555555"];
    Active [label="Active" shape=box style="rounded,filled" fillcolor="#f5f5f5" color="#555555"];
    NoticePeriod [label="Notice Period" shape=box style="rounded,filled" fillcolor="#f5f5f5" color="#555555"];
    Fulfilled [label="Fulfilled" shape=doublecircle style=filled fillcolor="#b7f5b7" color="#2e7d32" penwidth=2 width=1.2 height=1.2];
    ProbationExpired [label="Probation\nExpired" shape=doublecircle style=filled fillcolor="#fff9c4" color="#f57f17" penwidth=2 width=1.2 height=1.2];
    ContractExpired [label="Contract\nExpired" shape=doublecircle style=filled fillcolor="#fff9c4" color="#f57f17" penwidth=2 width=1.2 height=1.2];
    EmployeeBreached [label="Employee\nBreached" shape=doublecircle style=filled fillcolor="#ffcdd2" color="#c62828" penwidth=2 width=1.2 height=1.2];
    EmployerBreached [label="Employer\nBreached" shape=doublecircle style=filled fillcolor="#ffcdd2" color="#c62828" penwidth=2 width=1.2 height=1.2];

    // Transitions
    Probation -> Active [label="Probation Passed"];
    Probation -> EmployeeBreached [label="⚠ breach(Employee)"];
    Probation -> ProbationExpired [label="⏱ time_limit(probation_period)"];
    Active -> NoticePeriod [label="Resignation Received"];
    Active -> EmployeeBreached [label="⚠ breach(Employee)"];
    Active -> EmployerBreached [label="⚠ breach(Employer)"];
    Active -> ContractExpired [label="⏱ time_limit(contract_term)"];
    NoticePeriod -> Fulfilled [label="⏱ time_limit(notice_period)"];
    NoticePeriod -> EmployerBreached [label="⚠ breach(Employer)"];
}
